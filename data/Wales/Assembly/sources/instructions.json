{
  "sources": [
    {
      "file": "morph/p39s.csv",
      "create": {
        "from": "morph",
        "scraper": "mashedkeyboard/welsh-assembly-p39s",
        "query": "SELECT * FROM data ORDER BY id"
      },
      "source": "http://wikidata.org/",
      "type": "membership",
      "sourcetype": "wikidata"
    },
    {
      "file": "morph/official-6.csv",
      "create": {
        "from": "morph",
        "scraper": "mashedkeyboard/welsh-assembly",
        "query": "SELECT id,name,party,email,image FROM data ORDER BY id"
      },
      "source": "https://senedd.wales/",
      "type": "person",
      "merge": {
        "incoming_field": "name",
        "existing_field": "name",
        "reconciliation_file": "reconciliation/official-6.csv"
      }
    },
    {
      "file": "morph/wikidata.csv",
      "create": {
        "from": "morph",
        "scraper": "mashedkeyboard/wales-AMs-wikidata",
        "query": "SELECT * FROM data ORDER BY id"
      },
      "source": "http://wikidata.org/",
      "type": "wikidata",
      "merge": {
        "incoming_field": "name",
        "existing_field": "name",
        "reconciliation_file": "reconciliation/wikidata.csv"
      }
    },
    {
      "file": "archive/official-5.csv",
      "source": "http://www.assembly.wales/",
      "type": "person",
      "merge": {
        "incoming_field": "name",
        "existing_field": "name",
        "reconciliation_file": "reconciliation/official-5.csv"
      }
    },
    {
      "file": "archive/official-4.csv",
      "source": "http://www.assembly.wales/",
      "type": "person",
      "merge": {
        "incoming_field": "name",
        "existing_field": "name",
        "reconciliation_file": "reconciliation/official-4.csv"
      }
    },
    {
      "file": "wikidata/parties.json",
      "type": "group",
      "create": {
        "from": "group-wikidata",
        "source": "manual/group_wikidata.csv"
      }
    },
    {
      "file": "morph/terms.csv",
      "create": {
        "from": "morph",
        "scraper": "mashedkeyboard/welsh-assembly-terms-wikidata",
        "query": "SELECT * FROM data ORDER BY id"
      },
      "type": "term"
    },
    {
      "file": "morph/cabinet.csv",
      "type": "wikidata-cabinet",
      "create": {
        "from": "morph",
        "scraper": "everypolitician-scrapers/wales-positions",
        "query": "SELECT * FROM data ORDER BY id, position, start_date"
      }
    },
    {
      "file": "wikidata/elections.json",
      "type": "wikidata-elections",
      "create": {
        "from": "election-wikidata",
        "office": "Q3406079"
      }
    },
    {
      "file": "morph/areas.csv",
      "create": {
        "from": "morph",
        "scraper": "everypolitician-scrapers/welsh-assembly-constituencies-wikidata",
        "query": "SELECT * FROM data ORDER BY id"
      },
      "type": "area-wikidata",
      "merge": {
        "reconciliation_file": "reconciliation/areas.csv"
      }
    },
    {
      "file": "morph/twitter.csv",
      "create": {
        "from": "morph",
        "scraper": "everypolitician-scrapers/welsh-national-assembly-twitter-list",
        "query": "SELECT * FROM data ORDER BY id"
      },
      "type": "person",
      "source": "https://twitter.com/AssemblyWales/lists/assembly-members",
      "merge": {
        "incoming_field": "name",
        "existing_field": "name",
        "reconciliation_file": "reconciliation/twitter.csv",
        "patch": {
          "ignore": [
            "name",
            "image"
          ]
        }
      }
    }
  ]
}
